# IA,BRO! Agent OS — Configuración de Ejemplo
# Copia este archivo a ~/.iabro/config.toml y personalízalo a tu pinta.

# Configuración del servidor API
# api_key = ""                               # Activa esto para habilitar la autenticación Bearer (muy recomendado al exponerlo)
# api_listen = "127.0.0.1:50051"             # Dirección de enlace de la API HTTP.

# Usa "0.0.0.0:<puerto>" para exponer en LAN / Docker. El puerto debe
# coincidir con el que publiques (la imagen Docker expone el 4200). También puedes
# sobrescribirlo en tiempo de ejecución con IABRO_LISTEN=0.0.0.0:4200.

[default_model]
provider = "anthropic"                    # "anthropic", "gemini", "openai", "groq", "ollama", etc.
model = "claude-sonnet-4-20250514"        # Identificador del modelo por defecto
api_key_env = "ANTHROPIC_API_KEY"         # Variable de entorno que guarda la API key
# base_url = "https://api.anthropic.com"  # Opcional: para sobrescribir el endpoint de la API

[memory]
decay_rate = 0.05                         # Tasa de caída de confianza de la memoria
# sqlite_path = "~/.iabro/data/iabro.db"   # Opcional: ruta personalizada para la base de datos

[network]
listen_addr = "127.0.0.1:4200"           # Dirección de escucha de IA,BRO!
# shared_secret = ""                      # Requerido para la autenticación P2P (entre pares)

# Compactación de sesión (Gestión de contexto basada en LLM)
# [compaction]
# threshold = 80                          # Compactar cuando los mensajes superen esta cantidad
# keep_recent = 20                        # Mantener esta cantidad de mensajes recientes tras compactar
# max_summary_tokens = 1024               # Máximo de tokens para el resumen del LLM

# Visualización del seguimiento de uso
# usage_footer = "Full"                   # "Off", "Tokens", "Cost", o "Full"

# Adaptadores de canales (configura los tokens mediante variables de entorno)
# [telegram]
# bot_token_env = "TELEGRAM_BOT_TOKEN"
# allowed_users = []                      # Vacío = permitir a todos

# [discord]
# bot_token_env = "DISCORD_BOT_TOKEN"
# guild_ids = []                          # Vacío = todos los servidores

# [slack]
# bot_token_env = "SLACK_BOT_TOKEN"
# app_token_env = "SLACK_APP_TOKEN"

# Conexiones de servidores MCP (Model Context Protocol)
# [[mcp_servers]]
# name = "filesystem"
# command = "npx"
# args = ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"]
